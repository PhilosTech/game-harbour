# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database - local Docker
DATABASE_URL="postgresql://gamehubber:gamehubber@localhost:5433/gamehubber?schema=public"

# Database - Neon (production on Vercel)
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/gamehubber?sslmode=require"

# Auth.js (username + password, no email)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
ALLOW_HOST_REGISTRATION=true

# MinIO (local Docker) - S3-compatible
S3_ENDPOINT=http://localhost:19000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=gamehubber
S3_SECRET_ACCESS_KEY=gamehubber_secret
S3_BUCKET=gamehubber
S3_PUBLIC_URL=http://localhost:19000/gamehubber

# Production storage (e.g. Cloudflare R2)
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://cdn.yourdomain.com

# Realtime WebSocket (Socket.io)
REALTIME_PORT=3001
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
# Production (Render): NEXT_PUBLIC_REALTIME_URL=https://your-realtime.onrender.com
