{
  "name": "game-harbour",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,ws,prisma -c blue,magenta,yellow \"next dev\" \"npm run dev:realtime\" \"prisma generate --watch\"",
    "dev:next": "next dev",
    "dev:realtime": "tsx watch realtime/server.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@prisma/client": "^6.19.0",
    "@serwist/next": "^9.5.11",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "next": "^15.5.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.5.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "serwist": "^9.5.11",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.6",
    "ico-endec": "^0.1.6",
    "png-to-ico": "^3.0.1",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
